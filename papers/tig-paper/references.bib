\begin{abstract}
We analyze a constrained quadratic $f(R)$ gravity model exhibiting a critical transition in horizon formation. 
A dimensionless parameter $\beta$ controls the existence of horizons, with a critical value $\beta_c = (4/27)^{1/3}$ separating black hole geometries from horizonless compact objects.

We investigate modifications in photon-sphere structure, quasi-normal-mode (QNM) behavior, and late-time echo signatures. 
Near the critical regime, nonlinear deviations from Schwarzschild behavior arise, including frequency shifts and enhanced echo delays.

These features provide potential observational signatures in gravitational-wave \cite{LIGO2016} and black hole imaging data \cite{EHT2019}.
\end{abstract}

%--------------------------------------------------

\section{Introduction}

General Relativity \cite{Einstein1915,Wald1984} provides a highly successful description of gravity. Extensions based on $f(R)$ gravity \cite{Sotiriou2010,DeFelice2010,Capozziello2011} offer a minimal framework for incorporating higher-curvature corrections.

Regular black hole models have been proposed to resolve singularities \cite{Bardeen1968,Hayward2006}. In this work, we study a constrained quadratic model exhibiting a structural transition in horizon formation.

We show that this transition leads to observable consequences in quasi-normal-mode spectra \cite{Berti2009} and potential echo signatures \cite{Cardoso2016,Cardoso2017}.

%--------------------------------------------------

\section{Model Setup}

\begin{equation}
S = \int d^4x \sqrt{-g} \left[ \frac{1}{16\pi}(R - 2\Lambda) + \alpha R^2 \right]
\end{equation}

\begin{equation}
f(R) = R - 2\Lambda + \mu R^2
\end{equation}

\begin{equation}
m_\phi^2 = \frac{1}{6\mu}
\end{equation}

%--------------------------------------------------

\section{Static Solutions}

\begin{equation}
ds^2 = -F(r)dt^2 + \frac{dr^2}{F(r)} + r^2 d\Omega^2
\end{equation}

The metric should be interpreted as an effective solution capturing the qualitative features of modified gravity dynamics.

\begin{equation}
m(r) = \frac{Mr^3}{r^3 + r_c^3}
\end{equation}

\begin{equation}
F(r) = 1 - \frac{2m(r)}{r}
\end{equation}

%--------------------------------------------------

\section{Horizon Structure}

\begin{equation}
x^3 - x^2 + \beta^3 = 0
\end{equation}

\begin{equation}
\beta_c = \left(\frac{4}{27}\right)^{1/3}
\end{equation}

