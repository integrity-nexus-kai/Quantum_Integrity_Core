\documentclass[11pt]{article}

\usepackage{amsmath,amssymb}
\usepackage{graphicx}
\usepackage{geometry}
\geometry{margin=2.5cm}

\title{Metric-Induced Deviation of the Photon Sphere}
\author{}
\date{}

\begin{document}

\maketitle

\section{Introduction}

We analyze deviations of the photon sphere radius induced by a modified Schwarzschild geometry. The goal is to relate an observed functional deviation to an underlying correction in the metric structure.

\section{Metric Ansatz}

We consider a static, spherically symmetric spacetime:

\begin{equation}
ds^2 = -A(r)\,dt^2 + A(r)^{-1}dr^2 + r^2 d\Omega^2
\end{equation}

with a second-order correction:

\begin{equation}
A(r) = 1 - \frac{2M}{r} + \epsilon \frac{M^2}{r^2}
\end{equation}

\section{Photon Sphere Condition}

The effective potential for null geodesics is:

\begin{equation}
V_{\text{eff}}(r) = \frac{L^2}{r^2} A(r)
\end{equation}

The photon sphere is determined by:

\begin{equation}
\frac{d}{dr} \left( \frac{A(r)}{r^2} \right) = 0
\end{equation}

Substituting:

\begin{equation}
\frac{A(r)}{r^2}
=
\frac{1}{r^2}
-\frac{2M}{r^3}
+\epsilon\frac{M^2}{r^4}
\end{equation}

Differentiating:

\begin{equation}
-\frac{2}{r^3}
+\frac{6M}{r^4}
-\frac{4\epsilon M^2}{r^5}
= 0
\end{equation}

Multiplying by $r^5$:

\begin{equation}
-2r^2 + 6Mr - 4\epsilon M^2 = 0
\end{equation}

Rewriting:

\begin{equation}
r^2 - 3Mr + 2\epsilon M^2 = 0
\end{equation}

Solution:

\begin{equation}
r_{\text{ph}} =
\frac{M}{2}
\left(
3 + \sqrt{9 - 8\epsilon}
\right)
\end{equation}

\section{Relative Deviation}

Relative to the Schwarzschild value $r_{\text{ph}}^{\text{GR}} = 3M$:

\begin{equation}
\delta_{\text{ph}} =
\frac{r_{\text{ph}} - 3M}{3M}
\end{equation}

\begin{equation}
\delta_{\text{ph}} =
\frac{\sqrt{9 - 8\epsilon} - 3}{6}
\end{equation}

For small $\epsilon$:

\begin{equation}
\delta_{\text{ph}} \approx -\frac{2}{9}\epsilon
\end{equation}

\section{Model Matching}

Assuming a phenomenological deviation:

\begin{equation}
\delta(x) =
-0.04
\left(
1 - \frac{1}{x^2}
\right)
\quad,\quad
x = \frac{r_c}{2M}
\end{equation}

we obtain:

\begin{equation}
\epsilon(x) =
0.18
\left(
1 - \frac{1}{x^2}
\right)
\end{equation}

\section{Effective Metric}

The resulting metric function becomes:

\begin{equation}
A(r,x) =
1 - \frac{2M}{r}
+
0.18
\left(
1 - \frac{1}{x^2}
\right)
\frac{M^2}{r^2}
\end{equation}

\section{Visualization}

\begin{figure}[h!]
\centering
\includegraphics[width=0.7\textwidth]{tig_photon_sphere_deviation.png}
\caption{
Relative deviation of the photon sphere radius as a function of $r_c/(2M)$.
The deviation follows a saturating $x^{-2}$ behavior, indicating a second-order correction to the effective metric.
}
\end{figure}

\section{Conclusion}

The observed deviation is consistent with a second-order geometric correction to the Schwarzschild metric. The functional form of the deviation directly constrains the structure of the metric modification.

\end{document}
